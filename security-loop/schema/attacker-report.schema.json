{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geo-event-trigger-core-sdk/security-loop/schema/attacker-report.schema.json",
  "title": "Attacker Report",
  "type": "object",
  "required": [
    "schema_version",
    "module",
    "generated_at",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "finding_id",
        "module",
        "severity",
        "category",
        "evidence",
        "attack_path",
        "confidence"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info"
          ]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attack_path": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
